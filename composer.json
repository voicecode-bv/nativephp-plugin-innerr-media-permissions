{
    "name": "voicecode-bv/nativephp-plugin-innerr-media-permissions",
    "description": "NativePHP plugin that contributes iOS Info.plist usage descriptions for camera, microphone, and photo library access (Innerr).",
    "type": "nativephp-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Blijleven",
            "email": "michael@codingmonkeys.nl"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Voicecode\\InnerrMediaPermissions\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Voicecode\\InnerrMediaPermissions\\InnerrMediaPermissionsServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
